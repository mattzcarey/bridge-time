{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bridge-time",
  "main": "src/index.ts",
  "account_id": "543fbdef1eeaed8a02c251c8c4d9510b",
  "compatibility_date": "2026-04-20",
  "observability": {
    "logs": { "enabled": true },
    "traces": { "enabled": true }
  },
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 5, "period": 60 }
    }
  ]
}
